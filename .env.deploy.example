AWS_REGION=us-west-2

STATIC_VIEWER_STACK_NAME=humpback-static-viewer
STATIC_VIEWER_PRICE_CLASS=PriceClass_100

# Optional: pin bucket names instead of letting CDK name them.
STATIC_VIEWER_APP_BUCKET_NAME=
STATIC_VIEWER_DATA_BUCKET_NAME=

# Optional: custom domain support for the CloudFront distribution.
# The certificate ARN must refer to an ACM certificate in us-east-1.
STATIC_VIEWER_DOMAIN_NAME=
STATIC_VIEWER_CERTIFICATE_ARN=

# Optional: create Route 53 alias records when both values are set.
STATIC_VIEWER_HOSTED_ZONE_ID=
STATIC_VIEWER_HOSTED_ZONE_NAME=

# Required for publish commands unless --no-invalidate is used.
STATIC_VIEWER_DISTRIBUTION_ID=

# Optional default for `pnpm publish:viewer:data`.
TIMELINE_EXPORT_ROOT=
