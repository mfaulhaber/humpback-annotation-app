{
  "name": "@humpback/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --project tsconfig.json --pretty false",
    "build": "vite build",
    "test": "vitest run",
    "test:ui": "playwright test tests/ui/viewer-layout.spec.ts tests/ui/viewer-resize.spec.ts",
    "test:ui:visual": "playwright test tests/ui/viewer-visual.spec.ts",
    "test:ui:smoke": "PLAYWRIGHT_UI_MODE=smoke playwright test tests/ui/viewer-smoke.spec.ts",
    "test:ui:update": "playwright test tests/ui/viewer-visual.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@humpback/api": "workspace:*",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
