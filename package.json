{
  "name": "humpback-annotation-app",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace bootstrap for the Humpback Annotation App.",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "preinstall": "node ./scripts/check-node.mjs",
    "dev": "pnpm --filter @humpback/scripts run dev",
    "dev:timeline": "pnpm --filter @humpback/frontend dev",
    "deploy:viewer": "pnpm --filter @humpback/scripts run session-deploy",
    "typecheck": "pnpm -r --if-present run typecheck",
    "build": "pnpm -r --if-present run build",
    "test": "pnpm --filter @humpback/frontend test",
    "test:legacy": "pnpm --filter @humpback/tests test",
    "db:local:init": "pnpm --filter @humpback/scripts run db:local:init",
    "db:local:seed": "pnpm --filter @humpback/scripts run db:local:seed",
    "db:ingest": "pnpm --filter @humpback/scripts run db:ingest",
    "cdk:synth": "pnpm --filter @humpback/cdk run synth",
    "cdk:diff": "pnpm --filter @humpback/cdk run diff",
    "cdk:deploy": "pnpm --filter @humpback/cdk run deploy",
    "publish:viewer:app": "pnpm --filter @humpback/scripts run publish:static-viewer",
    "publish:viewer:data": "pnpm --filter @humpback/scripts run publish:timeline-data"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "22.19.15",
      "tsx": "4.21.0",
      "typescript": "5.9.3"
    }
  }
}
